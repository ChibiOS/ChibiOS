<clocktree>
  <settings>
    <prefixes clock_points="TCLK_" macros="TST_" cfgs="TST_CFG_" />
    <suffixes frequency="_FREQ" values="_VALUE" bits="_BITS"
              selector="_SEL" enable="_ENABLE" enabled="_ENABLED" />
    <configs>
      <config name="CLOCK_DYNAMIC" type="bool" default="FALSE"
              role="dynamic_mode">
        <description>Enables dynamic clock handling.</description>
      </config>
    </configs>
  </settings>
  <clocks>
    <clock point="NONE" enable="never" dynamic="no">
      <description>pseudo-clock for disabled sources</description>
      <source frequency="0U" />
    </clock>
    <clock point="LOWOSC" enable="manual" dynamic="no">
      <description>low speed oscillator demanded by a consumer</description>
      <bits enabled="RCC_LOWOSC_ON" disabled="0U" />
      <source frequency="32768U" />
    </clock>
    <clock point="RTC" enable="auto" dynamic="no">
      <description>auto-enabled RTC mux</description>
      <mux name="RTCSEL">
        <input point="NONE" default="yes"><bits value="RTCSEL_NONE" /></input>
        <input point="LOWOSC"><bits value="RTCSEL_LOWOSC" /></input>
      </mux>
    </clock>
  </clocks>
  <consumers>
    <consumer name="RTC_DRIVER" input="RTC" condition="HAL_USE_RTC == TRUE">
      <description>RTC driver demands the RTC clock when enabled</description>
    </consumer>
  </consumers>
</clocktree>
