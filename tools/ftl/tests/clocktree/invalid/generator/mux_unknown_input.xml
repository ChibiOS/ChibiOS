<clocktree>
  <settings>
    <prefixes clock_points="TCLK_" macros="TST_" cfgs="TST_CFG_" />
    <suffixes frequency="_FREQ" values="_VALUE" bits="_BITS"
              selector="_SEL" enable="_ENABLE" enabled="_ENABLED" />
    <configs>
      <config name="CLOCK_DYNAMIC" type="bool" default="FALSE"
              role="dynamic_mode">
        <description>Enables dynamic clock handling.</description>
      </config>
    </configs>
  </settings>
  <clocks>
    <clock point="A" enable="always" dynamic="no">
      <description>source A</description>
      <source frequency="1000000U" />
    </clock>
    <clock point="MUXED" enable="always" dynamic="no">
      <description>mux references missing input point</description>
      <mux name="MUXEDSEL">
        <input point="A" default="yes"><bits value="MUXEDSEL_A" /></input>
        <input point="MISSING"><bits value="MUXEDSEL_MISSING" /></input>
      </mux>
    </clock>
  </clocks>
</clocktree>
