<clocktree>
  <settings>
    <prefixes clock_points="TCLK_" macros="TST_" cfgs="TST_CFG_" />
    <suffixes frequency="_FREQ" values="_VALUE" bits="_BITS"
              selector="_SEL" enable="_ENABLE" enabled="_ENABLED" />
    <configs>
      <config name="CLOCK_DYNAMIC" type="bool" default="FALSE"
              role="dynamic_mode">
        <description>Enables dynamic clock handling.</description>
      </config>
    </configs>
  </settings>
  <clocks>
    <clock point="A" enable="always" dynamic="no">
      <description>input source</description>
      <source frequency="16000000U" />
    </clock>
    <clock point="B" enable="always" dynamic="no">
      <description>mux with unsupported targeted selection bits</description>
      <mux name="B">
        <input point="A" default="yes">
          <bits target="CFGR" value="B_SEL_A" />
        </input>
      </mux>
    </clock>
  </clocks>
</clocktree>
