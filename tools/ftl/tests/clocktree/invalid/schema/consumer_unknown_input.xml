<clocktree>
  <settings>
    <prefixes clock_points="TCLK_" macros="TST_" cfgs="TST_CFG_" />
    <suffixes frequency="_FREQ" values="_VALUE" bits="_BITS"
              selector="_SEL" enable="_ENABLE" enabled="_ENABLED" />
    <configs>
      <config name="CLOCK_DYNAMIC" type="bool" default="FALSE"
              role="dynamic_mode">
        <description>Enables dynamic clock handling.</description>
      </config>
    </configs>
  </settings>
  <clocks>
    <clock point="BASE" enable="always" dynamic="no">
      <description>base clock</description>
      <source frequency="1000000U" />
    </clock>
  </clocks>
  <consumers>
    <consumer name="DRIVER" input="MISSING">
      <description>consumer references a missing clock point</description>
    </consumer>
  </consumers>
</clocktree>
