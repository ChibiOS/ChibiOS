      <struct name="vfs_romfs_compressed_ops">
        <brief>ROMFS compression backend callbacks.</brief>
        <fields>
          <field name="open"
            ctype="msg_t$I(*)(const void *arg, int flags, void **sessionp, vfs_offset_t *sizep)">
          </field>
          <field name="close" ctype="void$I(*)(void *session)">
