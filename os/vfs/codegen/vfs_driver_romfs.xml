  name="drvromfs" descr="VFS ROMFS Driver"
  check="VFS_CFG_ENABLE_DRV_ROMFS == TRUE" sourcepath="drivers/romfs"
  headerpath="drivers/romfs" editcode="true">
  <imports>
    <import>vfs_nodes.xml</import>
    <import>vfs_drivers.xml</import>
