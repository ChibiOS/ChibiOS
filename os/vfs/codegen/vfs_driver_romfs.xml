    <definitions_early>
      <group description="ROMFS file kinds">
        <define name="VFS_ROMFS_FILE_TYPE_MASK" value="(3U &lt;&lt; 0)">
          <brief>Mask selecting the active file content variant.</brief>
        </define>
        <define name="VFS_ROMFS_FILE_TYPE_RAW" value="(0U &lt;&lt; 0)">
          <brief>File content is stored as an embedded byte array.</brief>
        </define>
        <define name="VFS_ROMFS_FILE_TYPE_DYNAMIC" value="(1U &lt;&lt; 0)">
          <brief>File content is generated by dynamic callbacks.</brief>
        </define>
        <define name="VFS_ROMFS_FILE_TYPE_COMPRESSED" value="(2U &lt;&lt; 0)">
          <brief>File content is provided through a compression backend.</brief>
        </define>
      </group>
    </definitions_early>
    <configs>
      <config name="DRV_CFG_ROM_ENABLE_COMPRESSION" default="FALSE">
        <brief>Enables support for compressed ROMFS file content.</brief>
      </config>
      <config name="DRV_CFG_ROM_DIR_NODES_NUM" default="1">
        <brief>Number of directory nodes pre-allocated in the pool.</brief>
        <assert invalid="$N &lt; 1" />
      </config>
      <config name="DRV_CFG_ROM_FILE_NODES_NUM" default="1">
        <brief>Number of file nodes pre-allocated in the pool.</brief>
        <assert invalid="$N &lt; 1" />
      </config>
    </configs>
