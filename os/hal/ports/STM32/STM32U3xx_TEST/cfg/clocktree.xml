<clocktree
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:noNamespaceSchemaLocation="http://www.chibios.org/xml/schema/clocks/clocktree.xsd">
  <settings>
    <prefixes clock_points="CLK_" macros="STM32_" cfgs="STM32_CFG_" />
    <suffixes frequency="_FREQ" values="_VALUE" bits="_BITS"
              selector="_SEL" enable="_ENABLE" enabled="_ENABLED" />
    <configs>
      <config name="CLOCK_DYNAMIC" type="bool" default="FALSE"
              role="dynamic_mode">
        <description>Enables dynamic clock handling.</description>
      </config>
      <config name="PWR_VOSR" type="set" default="PWR_VOSR_RANGE1"
              values="PWR_VOSR_RANGE1 PWR_VOSR_RANGE2">
        <description>Selects the core voltage scaling range.</description>
      </config>
      <config name="MSIRC0_MODE" type="set" default="RCC_MSIRC0_PLL_LSE"
              values="RCC_MSIRC0_FREE RCC_MSIRC0_PLL_LSE RCC_MSIRC0_PLL_HSE RCC_MSIRC0_PLL_LSE_FAST RCC_MSIRC0_PLL_HSE_FAST">
        <description>Selects the MSIRC0 operating mode.</description>
      </config>
      <config name="MSIRC1_MODE" type="set" default="RCC_MSIRC1_FREE"
              values="RCC_MSIRC1_FREE RCC_MSIRC1_PLL_LSE RCC_MSIRC1_PLL_HSE RCC_MSIRC1_PLL_LSE_FAST RCC_MSIRC1_PLL_HSE_FAST">
        <description>Selects the MSIRC1 operating mode.</description>
      </config>
      <config name="MSIPLL1N_VALUE" type="set" default="0"
              values="0 1 2 3">
        <description>Selects the MSIRC1 PLL correction factor.</description>
      </config>
      <config name="MSIS_SRCDIV" type="set" default="RCC_ICSCR1_MSIS_IRC0_DIV1"
              values="RCC_ICSCR1_MSIS_IRC0_DIV1 RCC_ICSCR1_MSIS_IRC0_DIV2 RCC_ICSCR1_MSIS_IRC0_DIV4 RCC_ICSCR1_MSIS_IRC0_DIV8 RCC_ICSCR1_MSIS_IRC1_DIV1 RCC_ICSCR1_MSIS_IRC1_DIV2 RCC_ICSCR1_MSIS_IRC1_DIV4 RCC_ICSCR1_MSIS_IRC1_DIV8">
        <description>Selects the source and divide factor for MSIS.</description>
      </config>
      <config name="MSIK_SRCDIV" type="set" default="RCC_ICSCR1_MSIK_IRC0_DIV1"
              values="RCC_ICSCR1_MSIK_IRC0_DIV1 RCC_ICSCR1_MSIK_IRC0_DIV2 RCC_ICSCR1_MSIK_IRC0_DIV4 RCC_ICSCR1_MSIK_IRC0_DIV8 RCC_ICSCR1_MSIK_IRC1_DIV1 RCC_ICSCR1_MSIK_IRC1_DIV2 RCC_ICSCR1_MSIK_IRC1_DIV4 RCC_ICSCR1_MSIK_IRC1_DIV8">
        <description>Selects the source and divide factor for MSIK.</description>
      </config>
    </configs>
  </settings>
  <clocks>
    <clock point="NONE" enable="never" dynamic="no">
      <description>pseudo-clock for disabled sources</description>
      <source frequency="0U" />
    </clock>
    <clock point="HSI16" enable="manual" dynamic="yes">
      <description>16MHz high speed internal oscillator</description>
      <bits enabled="(RCC_CR_HSION | RCC_CR_HSIKERON)" disabled="0U" />
      <source frequency="16000000U" />
    </clock>
    <clock point="HSI48" enable="manual" dynamic="yes">
      <description>48MHz high speed internal oscillator</description>
      <bits enabled="RCC_CR_HSI48ON" disabled="0U" />
      <source frequency="48000000U" />
    </clock>
    <clock point="HSE" enable="manual" dynamic="yes">
      <description>high frequency external oscillator</description>
      <bits enabled="RCC_CR_HSEON" disabled="0U" />
      <source frequency="STM32_HSECLK" />
    </clock>
    <clock point="LSE" enable="manual" dynamic="no">
      <description>low frequency external oscillator</description>
      <bits enabled="RCC_BDCR_LSEON" disabled="0U" />
      <source frequency="STM32_LSECLK" />
    </clock>
    <clock point="LSI" enable="manual" dynamic="no">
      <description>low frequency internal oscillator</description>
      <bits enabled="RCC_CSR_LSION" disabled="0U" />
      <source frequency="STM32_LSICLK" />
    </clock>

    <clock point="MSIRC0" enable="auto" dynamic="no">
      <description>MSI 96MHz internal oscillator</description>
      <source>
        <frequencies>
          <select>
            <when condition="STM32_CFG_MSIRC0_MODE == RCC_MSIRC0_PLL_LSE"
                  value="96010000U">
              <bits target="CR" value="RCC_CR_MSIPLL0EN" />
              <bits target="ICSCR1" value="RCC_ICSCR1_MSIPLL0SEL_LSE" />
            </when>
            <when condition="STM32_CFG_MSIRC0_MODE == RCC_MSIRC0_PLL_HSE"
                  value="96000000U">
              <bits target="CR" value="RCC_CR_MSIPLL0EN" />
              <bits target="ICSCR1" value="(RCC_ICSCR1_MSIPLL0SEL_HSE | STM32_MSIHSINDIV)" />
            </when>
            <when condition="STM32_CFG_MSIRC0_MODE == RCC_MSIRC0_PLL_LSE_FAST"
                  value="96010000U">
              <bits target="CR" value="(RCC_CR_MSIPLL0EN | RCC_CR_MSIPLL0FAST)" />
              <bits target="ICSCR1" value="RCC_ICSCR1_MSIPLL0SEL_LSE" />
            </when>
            <when condition="STM32_CFG_MSIRC0_MODE == RCC_MSIRC0_PLL_HSE_FAST"
                  value="96000000U">
              <bits target="CR" value="(RCC_CR_MSIPLL0EN | RCC_CR_MSIPLL0FAST)" />
              <bits target="ICSCR1" value="(RCC_ICSCR1_MSIPLL0SEL_HSE | STM32_MSIHSINDIV)" />
            </when>
            <otherwise value="96000000U">
              <bits target="CR" value="0U" />
              <bits target="ICSCR1" value="0U" />
            </otherwise>
          </select>
        </frequencies>
      </source>
    </clock>
    <clock point="MSIRC1" enable="auto" dynamic="no">
      <description>MSI 24MHz internal oscillator</description>
      <source>
        <frequencies>
          <select>
            <when condition="STM32_CFG_MSIRC1_MODE == RCC_MSIRC1_PLL_LSE">
              <bits target="CR" value="RCC_CR_MSIPLL1EN" />
              <bits target="ICSCR1" value="(RCC_ICSCR1_MSIPLL1SEL_LSE | RCC_ICSCR1_MSIPLL1N_FIELD(STM32_CFG_MSIPLL1N_VALUE))" />
              <select>
                <when condition="(STM32_CFG_MSIPLL1N_VALUE == 0) || (STM32_CFG_MSIPLL1N_VALUE == 1)"
                      value="23986000U" />
                <when condition="STM32_CFG_MSIPLL1N_VALUE == 2" value="22577000U" />
                <when condition="STM32_CFG_MSIPLL1N_VALUE == 3" value="24576000U" />
                <otherwise value="24000000U" />
              </select>
            </when>
            <when condition="STM32_CFG_MSIRC1_MODE == RCC_MSIRC1_PLL_HSE">
              <bits target="CR" value="RCC_CR_MSIPLL1EN" />
              <bits target="ICSCR1" value="(RCC_ICSCR1_MSIPLL1SEL_HSE | RCC_ICSCR1_MSIPLL1N_FIELD(STM32_CFG_MSIPLL1N_VALUE) | STM32_MSIHSINDIV)" />
              <select>
                <when condition="(STM32_CFG_MSIPLL1N_VALUE == 0) || (STM32_CFG_MSIPLL1N_VALUE == 1)"
                      value="24016000U" />
                <when condition="STM32_CFG_MSIPLL1N_VALUE == 2" value="22581000U" />
                <when condition="STM32_CFG_MSIPLL1N_VALUE == 3" value="24577000U" />
                <otherwise value="24000000U" />
              </select>
            </when>
            <when condition="STM32_CFG_MSIRC1_MODE == RCC_MSIRC1_PLL_LSE_FAST">
              <bits target="CR" value="(RCC_CR_MSIPLL1EN | RCC_CR_MSIPLL1FAST)" />
              <bits target="ICSCR1" value="(RCC_ICSCR1_MSIPLL1SEL_LSE | RCC_ICSCR1_MSIPLL1N_FIELD(STM32_CFG_MSIPLL1N_VALUE))" />
              <select>
                <when condition="(STM32_CFG_MSIPLL1N_VALUE == 0) || (STM32_CFG_MSIPLL1N_VALUE == 1)"
                      value="23986000U" />
                <when condition="STM32_CFG_MSIPLL1N_VALUE == 2" value="22577000U" />
                <when condition="STM32_CFG_MSIPLL1N_VALUE == 3" value="24576000U" />
                <otherwise value="24000000U" />
              </select>
            </when>
            <when condition="STM32_CFG_MSIRC1_MODE == RCC_MSIRC1_PLL_HSE_FAST">
              <bits target="CR" value="(RCC_CR_MSIPLL1EN | RCC_CR_MSIPLL1FAST)" />
              <bits target="ICSCR1" value="(RCC_ICSCR1_MSIPLL1SEL_HSE | RCC_ICSCR1_MSIPLL1N_FIELD(STM32_CFG_MSIPLL1N_VALUE) | STM32_MSIHSINDIV)" />
              <select>
                <when condition="(STM32_CFG_MSIPLL1N_VALUE == 0) || (STM32_CFG_MSIPLL1N_VALUE == 1)"
                      value="24016000U" />
                <when condition="STM32_CFG_MSIPLL1N_VALUE == 2" value="22581000U" />
                <when condition="STM32_CFG_MSIPLL1N_VALUE == 3" value="24577000U" />
                <otherwise value="24000000U" />
              </select>
            </when>
            <otherwise value="24000000U">
              <bits target="CR" value="0U" />
              <bits target="ICSCR1" value="0U" />
            </otherwise>
          </select>
        </frequencies>
      </source>
    </clock>

    <clock point="MSIS" enable="auto" dynamic="yes">
      <description>MSI system oscillator</description>
      <bits target="CR" enabled="RCC_CR_MSISON" disabled="0U" />
      <source>
        <frequencies>
          <case when="(STM32_CFG_MSIS_SRCDIV == RCC_ICSCR1_MSIS_IRC0_DIV1) &amp;&amp; ((STM32_CFG_MSIRC0_MODE == RCC_MSIRC0_PLL_LSE) || (STM32_CFG_MSIRC0_MODE == RCC_MSIRC0_PLL_LSE_FAST))" value="96010000U">
            <bits target="ICSCR1" value="(RCC_ICSCR1_MSISSEL_MSIRC0 | RCC_ICSCR1_MSISDIV_FIELD(0U))" />
          </case>
          <case when="(STM32_CFG_MSIS_SRCDIV == RCC_ICSCR1_MSIS_IRC0_DIV1)" value="96000000U">
            <bits target="ICSCR1" value="(RCC_ICSCR1_MSISSEL_MSIRC0 | RCC_ICSCR1_MSISDIV_FIELD(0U))" />
          </case>
          <case when="(STM32_CFG_MSIS_SRCDIV == RCC_ICSCR1_MSIS_IRC0_DIV2) &amp;&amp; ((STM32_CFG_MSIRC0_MODE == RCC_MSIRC0_PLL_LSE) || (STM32_CFG_MSIRC0_MODE == RCC_MSIRC0_PLL_LSE_FAST))" value="48005000U">
            <bits target="ICSCR1" value="(RCC_ICSCR1_MSISSEL_MSIRC0 | RCC_ICSCR1_MSISDIV_FIELD(1U))" />
          </case>
          <case when="(STM32_CFG_MSIS_SRCDIV == RCC_ICSCR1_MSIS_IRC0_DIV2)" value="48000000U">
            <bits target="ICSCR1" value="(RCC_ICSCR1_MSISSEL_MSIRC0 | RCC_ICSCR1_MSISDIV_FIELD(1U))" />
          </case>
          <case when="(STM32_CFG_MSIS_SRCDIV == RCC_ICSCR1_MSIS_IRC0_DIV4) &amp;&amp; ((STM32_CFG_MSIRC0_MODE == RCC_MSIRC0_PLL_LSE) || (STM32_CFG_MSIRC0_MODE == RCC_MSIRC0_PLL_LSE_FAST))" value="24002500U">
            <bits target="ICSCR1" value="(RCC_ICSCR1_MSISSEL_MSIRC0 | RCC_ICSCR1_MSISDIV_FIELD(2U))" />
          </case>
          <case when="(STM32_CFG_MSIS_SRCDIV == RCC_ICSCR1_MSIS_IRC0_DIV4)" value="24000000U">
            <bits target="ICSCR1" value="(RCC_ICSCR1_MSISSEL_MSIRC0 | RCC_ICSCR1_MSISDIV_FIELD(2U))" />
          </case>
          <case when="(STM32_CFG_MSIS_SRCDIV == RCC_ICSCR1_MSIS_IRC0_DIV8) &amp;&amp; ((STM32_CFG_MSIRC0_MODE == RCC_MSIRC0_PLL_LSE) || (STM32_CFG_MSIRC0_MODE == RCC_MSIRC0_PLL_LSE_FAST))" value="12001250U">
            <bits target="ICSCR1" value="(RCC_ICSCR1_MSISSEL_MSIRC0 | RCC_ICSCR1_MSISDIV_FIELD(3U))" />
          </case>
          <case when="(STM32_CFG_MSIS_SRCDIV == RCC_ICSCR1_MSIS_IRC0_DIV8)" value="12000000U">
            <bits target="ICSCR1" value="(RCC_ICSCR1_MSISSEL_MSIRC0 | RCC_ICSCR1_MSISDIV_FIELD(3U))" />
          </case>

          <case when="(STM32_CFG_MSIS_SRCDIV == RCC_ICSCR1_MSIS_IRC1_DIV1) &amp;&amp; ((STM32_CFG_MSIPLL1N_VALUE == 0) || (STM32_CFG_MSIPLL1N_VALUE == 1)) &amp;&amp; ((STM32_CFG_MSIRC1_MODE == RCC_MSIRC1_PLL_LSE) || (STM32_CFG_MSIRC1_MODE == RCC_MSIRC1_PLL_LSE_FAST))" value="23986000U">
            <bits target="ICSCR1" value="(RCC_ICSCR1_MSISSEL_MSIRC1 | RCC_ICSCR1_MSISDIV_FIELD(0U))" />
          </case>
          <case when="(STM32_CFG_MSIS_SRCDIV == RCC_ICSCR1_MSIS_IRC1_DIV1) &amp;&amp; ((STM32_CFG_MSIPLL1N_VALUE == 0) || (STM32_CFG_MSIPLL1N_VALUE == 1)) &amp;&amp; ((STM32_CFG_MSIRC1_MODE == RCC_MSIRC1_PLL_HSE) || (STM32_CFG_MSIRC1_MODE == RCC_MSIRC1_PLL_HSE_FAST))" value="24016000U">
            <bits target="ICSCR1" value="(RCC_ICSCR1_MSISSEL_MSIRC1 | RCC_ICSCR1_MSISDIV_FIELD(0U))" />
          </case>
          <case when="(STM32_CFG_MSIS_SRCDIV == RCC_ICSCR1_MSIS_IRC1_DIV1) &amp;&amp; (STM32_CFG_MSIPLL1N_VALUE == 2) &amp;&amp; ((STM32_CFG_MSIRC1_MODE == RCC_MSIRC1_PLL_LSE) || (STM32_CFG_MSIRC1_MODE == RCC_MSIRC1_PLL_LSE_FAST))" value="22577000U">
            <bits target="ICSCR1" value="(RCC_ICSCR1_MSISSEL_MSIRC1 | RCC_ICSCR1_MSISDIV_FIELD(0U))" />
          </case>
          <case when="(STM32_CFG_MSIS_SRCDIV == RCC_ICSCR1_MSIS_IRC1_DIV1) &amp;&amp; (STM32_CFG_MSIPLL1N_VALUE == 2) &amp;&amp; ((STM32_CFG_MSIRC1_MODE == RCC_MSIRC1_PLL_HSE) || (STM32_CFG_MSIRC1_MODE == RCC_MSIRC1_PLL_HSE_FAST))" value="22581000U">
            <bits target="ICSCR1" value="(RCC_ICSCR1_MSISSEL_MSIRC1 | RCC_ICSCR1_MSISDIV_FIELD(0U))" />
          </case>
          <case when="(STM32_CFG_MSIS_SRCDIV == RCC_ICSCR1_MSIS_IRC1_DIV1) &amp;&amp; (STM32_CFG_MSIPLL1N_VALUE == 3) &amp;&amp; ((STM32_CFG_MSIRC1_MODE == RCC_MSIRC1_PLL_LSE) || (STM32_CFG_MSIRC1_MODE == RCC_MSIRC1_PLL_LSE_FAST))" value="24576000U">
            <bits target="ICSCR1" value="(RCC_ICSCR1_MSISSEL_MSIRC1 | RCC_ICSCR1_MSISDIV_FIELD(0U))" />
          </case>
          <case when="(STM32_CFG_MSIS_SRCDIV == RCC_ICSCR1_MSIS_IRC1_DIV1) &amp;&amp; (STM32_CFG_MSIPLL1N_VALUE == 3) &amp;&amp; ((STM32_CFG_MSIRC1_MODE == RCC_MSIRC1_PLL_HSE) || (STM32_CFG_MSIRC1_MODE == RCC_MSIRC1_PLL_HSE_FAST))" value="24577000U">
            <bits target="ICSCR1" value="(RCC_ICSCR1_MSISSEL_MSIRC1 | RCC_ICSCR1_MSISDIV_FIELD(0U))" />
          </case>
          <case when="(STM32_CFG_MSIS_SRCDIV == RCC_ICSCR1_MSIS_IRC1_DIV1)" value="24000000U">
            <bits target="ICSCR1" value="(RCC_ICSCR1_MSISSEL_MSIRC1 | RCC_ICSCR1_MSISDIV_FIELD(0U))" />
          </case>

          <case when="(STM32_CFG_MSIS_SRCDIV == RCC_ICSCR1_MSIS_IRC1_DIV2) &amp;&amp; ((STM32_CFG_MSIPLL1N_VALUE == 0) || (STM32_CFG_MSIPLL1N_VALUE == 1)) &amp;&amp; ((STM32_CFG_MSIRC1_MODE == RCC_MSIRC1_PLL_LSE) || (STM32_CFG_MSIRC1_MODE == RCC_MSIRC1_PLL_LSE_FAST))" value="11993000U">
            <bits target="ICSCR1" value="(RCC_ICSCR1_MSISSEL_MSIRC1 | RCC_ICSCR1_MSISDIV_FIELD(1U))" />
          </case>
          <case when="(STM32_CFG_MSIS_SRCDIV == RCC_ICSCR1_MSIS_IRC1_DIV2) &amp;&amp; ((STM32_CFG_MSIPLL1N_VALUE == 0) || (STM32_CFG_MSIPLL1N_VALUE == 1)) &amp;&amp; ((STM32_CFG_MSIRC1_MODE == RCC_MSIRC1_PLL_HSE) || (STM32_CFG_MSIRC1_MODE == RCC_MSIRC1_PLL_HSE_FAST))" value="12008000U">
            <bits target="ICSCR1" value="(RCC_ICSCR1_MSISSEL_MSIRC1 | RCC_ICSCR1_MSISDIV_FIELD(1U))" />
          </case>
          <case when="(STM32_CFG_MSIS_SRCDIV == RCC_ICSCR1_MSIS_IRC1_DIV2) &amp;&amp; (STM32_CFG_MSIPLL1N_VALUE == 2) &amp;&amp; ((STM32_CFG_MSIRC1_MODE == RCC_MSIRC1_PLL_LSE) || (STM32_CFG_MSIRC1_MODE == RCC_MSIRC1_PLL_LSE_FAST))" value="11288500U">
            <bits target="ICSCR1" value="(RCC_ICSCR1_MSISSEL_MSIRC1 | RCC_ICSCR1_MSISDIV_FIELD(1U))" />
          </case>
          <case when="(STM32_CFG_MSIS_SRCDIV == RCC_ICSCR1_MSIS_IRC1_DIV2) &amp;&amp; (STM32_CFG_MSIPLL1N_VALUE == 2) &amp;&amp; ((STM32_CFG_MSIRC1_MODE == RCC_MSIRC1_PLL_HSE) || (STM32_CFG_MSIRC1_MODE == RCC_MSIRC1_PLL_HSE_FAST))" value="11290500U">
            <bits target="ICSCR1" value="(RCC_ICSCR1_MSISSEL_MSIRC1 | RCC_ICSCR1_MSISDIV_FIELD(1U))" />
          </case>
          <case when="(STM32_CFG_MSIS_SRCDIV == RCC_ICSCR1_MSIS_IRC1_DIV2) &amp;&amp; (STM32_CFG_MSIPLL1N_VALUE == 3) &amp;&amp; ((STM32_CFG_MSIRC1_MODE == RCC_MSIRC1_PLL_LSE) || (STM32_CFG_MSIRC1_MODE == RCC_MSIRC1_PLL_LSE_FAST))" value="12288000U">
            <bits target="ICSCR1" value="(RCC_ICSCR1_MSISSEL_MSIRC1 | RCC_ICSCR1_MSISDIV_FIELD(1U))" />
          </case>
          <case when="(STM32_CFG_MSIS_SRCDIV == RCC_ICSCR1_MSIS_IRC1_DIV2) &amp;&amp; (STM32_CFG_MSIPLL1N_VALUE == 3) &amp;&amp; ((STM32_CFG_MSIRC1_MODE == RCC_MSIRC1_PLL_HSE) || (STM32_CFG_MSIRC1_MODE == RCC_MSIRC1_PLL_HSE_FAST))" value="12288500U">
            <bits target="ICSCR1" value="(RCC_ICSCR1_MSISSEL_MSIRC1 | RCC_ICSCR1_MSISDIV_FIELD(1U))" />
          </case>
          <case when="(STM32_CFG_MSIS_SRCDIV == RCC_ICSCR1_MSIS_IRC1_DIV2)" value="12000000U">
            <bits target="ICSCR1" value="(RCC_ICSCR1_MSISSEL_MSIRC1 | RCC_ICSCR1_MSISDIV_FIELD(1U))" />
          </case>

          <case when="(STM32_CFG_MSIS_SRCDIV == RCC_ICSCR1_MSIS_IRC1_DIV4) &amp;&amp; ((STM32_CFG_MSIPLL1N_VALUE == 0) || (STM32_CFG_MSIPLL1N_VALUE == 1)) &amp;&amp; ((STM32_CFG_MSIRC1_MODE == RCC_MSIRC1_PLL_LSE) || (STM32_CFG_MSIRC1_MODE == RCC_MSIRC1_PLL_LSE_FAST))" value="5996500U">
            <bits target="ICSCR1" value="(RCC_ICSCR1_MSISSEL_MSIRC1 | RCC_ICSCR1_MSISDIV_FIELD(2U))" />
          </case>
          <case when="(STM32_CFG_MSIS_SRCDIV == RCC_ICSCR1_MSIS_IRC1_DIV4) &amp;&amp; ((STM32_CFG_MSIPLL1N_VALUE == 0) || (STM32_CFG_MSIPLL1N_VALUE == 1)) &amp;&amp; ((STM32_CFG_MSIRC1_MODE == RCC_MSIRC1_PLL_HSE) || (STM32_CFG_MSIRC1_MODE == RCC_MSIRC1_PLL_HSE_FAST))" value="6004000U">
            <bits target="ICSCR1" value="(RCC_ICSCR1_MSISSEL_MSIRC1 | RCC_ICSCR1_MSISDIV_FIELD(2U))" />
          </case>
          <case when="(STM32_CFG_MSIS_SRCDIV == RCC_ICSCR1_MSIS_IRC1_DIV4) &amp;&amp; (STM32_CFG_MSIPLL1N_VALUE == 2) &amp;&amp; ((STM32_CFG_MSIRC1_MODE == RCC_MSIRC1_PLL_LSE) || (STM32_CFG_MSIRC1_MODE == RCC_MSIRC1_PLL_LSE_FAST))" value="5644250U">
            <bits target="ICSCR1" value="(RCC_ICSCR1_MSISSEL_MSIRC1 | RCC_ICSCR1_MSISDIV_FIELD(2U))" />
          </case>
          <case when="(STM32_CFG_MSIS_SRCDIV == RCC_ICSCR1_MSIS_IRC1_DIV4) &amp;&amp; (STM32_CFG_MSIPLL1N_VALUE == 2) &amp;&amp; ((STM32_CFG_MSIRC1_MODE == RCC_MSIRC1_PLL_HSE) || (STM32_CFG_MSIRC1_MODE == RCC_MSIRC1_PLL_HSE_FAST))" value="5645250U">
            <bits target="ICSCR1" value="(RCC_ICSCR1_MSISSEL_MSIRC1 | RCC_ICSCR1_MSISDIV_FIELD(2U))" />
          </case>
          <case when="(STM32_CFG_MSIS_SRCDIV == RCC_ICSCR1_MSIS_IRC1_DIV4) &amp;&amp; (STM32_CFG_MSIPLL1N_VALUE == 3) &amp;&amp; ((STM32_CFG_MSIRC1_MODE == RCC_MSIRC1_PLL_LSE) || (STM32_CFG_MSIRC1_MODE == RCC_MSIRC1_PLL_LSE_FAST))" value="6144000U">
            <bits target="ICSCR1" value="(RCC_ICSCR1_MSISSEL_MSIRC1 | RCC_ICSCR1_MSISDIV_FIELD(2U))" />
          </case>
          <case when="(STM32_CFG_MSIS_SRCDIV == RCC_ICSCR1_MSIS_IRC1_DIV4) &amp;&amp; (STM32_CFG_MSIPLL1N_VALUE == 3) &amp;&amp; ((STM32_CFG_MSIRC1_MODE == RCC_MSIRC1_PLL_HSE) || (STM32_CFG_MSIRC1_MODE == RCC_MSIRC1_PLL_HSE_FAST))" value="6144250U">
            <bits target="ICSCR1" value="(RCC_ICSCR1_MSISSEL_MSIRC1 | RCC_ICSCR1_MSISDIV_FIELD(2U))" />
          </case>
          <case when="(STM32_CFG_MSIS_SRCDIV == RCC_ICSCR1_MSIS_IRC1_DIV4)" value="6000000U">
            <bits target="ICSCR1" value="(RCC_ICSCR1_MSISSEL_MSIRC1 | RCC_ICSCR1_MSISDIV_FIELD(2U))" />
          </case>

          <case when="(STM32_CFG_MSIS_SRCDIV == RCC_ICSCR1_MSIS_IRC1_DIV8) &amp;&amp; ((STM32_CFG_MSIPLL1N_VALUE == 0) || (STM32_CFG_MSIPLL1N_VALUE == 1)) &amp;&amp; ((STM32_CFG_MSIRC1_MODE == RCC_MSIRC1_PLL_LSE) || (STM32_CFG_MSIRC1_MODE == RCC_MSIRC1_PLL_LSE_FAST))" value="2998250U">
            <bits target="ICSCR1" value="(RCC_ICSCR1_MSISSEL_MSIRC1 | RCC_ICSCR1_MSISDIV_FIELD(3U))" />
          </case>
          <case when="(STM32_CFG_MSIS_SRCDIV == RCC_ICSCR1_MSIS_IRC1_DIV8) &amp;&amp; ((STM32_CFG_MSIPLL1N_VALUE == 0) || (STM32_CFG_MSIPLL1N_VALUE == 1)) &amp;&amp; ((STM32_CFG_MSIRC1_MODE == RCC_MSIRC1_PLL_HSE) || (STM32_CFG_MSIRC1_MODE == RCC_MSIRC1_PLL_HSE_FAST))" value="3002000U">
