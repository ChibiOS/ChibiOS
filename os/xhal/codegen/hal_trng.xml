  name="hal_trng" descr="TRNG Driver" check="HAL_USE_TRNG == TRUE"
  editcode="false">
  <brief>TRNG Driver macros and structures.</brief>
  <imports>
    <import>hal_base_driver.xml</import>
  </imports>
